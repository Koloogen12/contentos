# ============================================================
# Production .env — lives at /opt/contentos/.env on the VPS.
# Generated once by deploy.sh and re-used on subsequent deploys.
# Anything you change here takes effect on the next `docker compose up`.
# ============================================================

# --- Domain ---
# Set to your real domain to get auto-Let's Encrypt SSL.
# Leave as "_" to bootstrap with a self-signed cert (use https://<vps-ip>).
DOMAIN=_
ACME_EMAIL=

# Public-facing URLs Caddy will route. The frontend bundle bakes
# PUBLIC_URL_API into client-side code at build time, so DOMAIN must
# match these.
PUBLIC_URL_API=https://api.example.com
PUBLIC_URL_FRONT=https://example.com

# --- App secrets (filled in by deploy.sh on first run) ---
JWT_SECRET=
SECRETS_ENCRYPTION_KEY=

# --- Postgres (in-container) ---
POSTGRES_DB=contentos
POSTGRES_USER=contentos
POSTGRES_PASSWORD=

# --- AI provider ---
COMETAPI_KEY=
COMETAPI_BASE_URL=https://api.cometapi.com/v1
COMETAPI_MODEL=claude-sonnet-4-6
COMETAPI_MODEL_EMBEDDING=text-embedding-3-small
COMETAPI_MODEL_WHISPER=whisper-1

# --- Telegram (default bot used when target.bot_token is empty) ---
TELEGRAM_BOT_TOKEN=

# --- Storage ---
# Empty = local files in the media-cache volume. For S3, fill all four.
S3_ENDPOINT_URL=
S3_REGION=ru-1
S3_BUCKET=contentos-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Limits ---
MAX_UPLOAD_SIZE_MB=500
TEMP_DIR=/tmp/contentos
