# ContentOS production .env (Selectel mml-prod-1).
# Lives at /opt/contentos/deploy/.env on the server. Combined with
# /etc/contentos/secrets.env (root, mode 600) at compose-up time.
#
# Single-domain mode: same host serves both frontend and /api/.
# api.* subdomain support is V2 (split host requires a second A-record + cert).

DOMAIN=draft.neurin.tech
PUBLIC_URL_FRONT=https://draft.neurin.tech
PUBLIC_URL_API=https://draft.neurin.tech
ACME_EMAIL=leomih659@gmail.com
