# --- App ---
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# --- Database ---
# Async URL for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://contentos:contentos@localhost:5432/contentos
# Sync URL for Alembic
DATABASE_SYNC_URL=postgresql+psycopg://contentos:contentos@localhost:5432/contentos

# --- Redis (Arq queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# --- AI provider (CometAPI, OpenAI-compatible) ---
COMETAPI_KEY=
COMETAPI_BASE_URL=https://api.cometapi.com/v1
COMETAPI_MODEL=claude-sonnet-4-6
COMETAPI_MODEL_EMBEDDING=text-embedding-3-small
COMETAPI_MODEL_WHISPER=whisper-1

# --- Storage (S3-compatible, Selectel later) ---
S3_ENDPOINT_URL=
S3_REGION=ru-1
S3_BUCKET=contentos-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Telegram ---
# Default bot for posting (per-org bots are configurable in DB later)
TELEGRAM_BOT_TOKEN=

# --- CORS / Frontend ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Limits ---
MAX_UPLOAD_SIZE_MB=500
TEMP_DIR=/tmp/contentos
